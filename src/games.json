    "id": "1v1-lol",
    "title": "1v1.lol",
    "description": "A competitive 3D third-person shooter where you build and fight. Master your construction skills to dominate the arena.",
    "thumbnail": "https://external-content.duckduckgo.com/iu/?u=https%3A%2F%2Fimgs2.dab3games.com%2F1v1-lol-game30.png&f=1&nofb=1&ipt=047c20fa94aff44401efffb73f265b7ad58353b65d454def1ceb4214ca16f122",
    "html": "<html>\n   <head>\n    <style>\n      body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center; }\n      .webgl-content { width: 100% !important; height: 100% !important; display: flex !important; align-items: center; justify-content: center; }\n      #gameContainer { width: 100% !important; height: 100% !important; }\n      canvas { width: 100% !important; height: 100% !important; display: block; object-fit: contain; }\n    </style>\n    <script>\n        window.dataLayer = window.dataLayer || [];\n\n        function gtag() {\n            dataLayer.push(arguments);\n        }\n        gtag('js', new Date());\n        gtag('config', 'G-WX5VS54ZDW');\n    </script>\n      <meta charset=\"utf-8\">\n      <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n      <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/style.css\">\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/UnityProgress.js\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/2.7.js\"></script>\n      <script type=\"text/javascript\">\n        var gameInstance;\n        window.onload = function() {\n            gameInstance = UnityLoader.instantiate(\"gameContainer\", \"https://cdn.jsdelivr.net/gh/n-101-1/1@main/2.7.json\", {\n                onProgress: UnityProgress,\n                Module: {\n                    onRuntimeInitialized: function() {\n                        UnityProgress(gameInstance, \"complete\");\n                    },\n                },\n            });\n        };\n      </script> \n   </head>\n   <body>\n      <div class=\"webgl-content\">\n         <div id=\"gameContainer\" style=\"width: 100%; height: 100%; margin: auto;\"></div>\n      </div>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1firebase-app.js\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1firebase-auth.js\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1firebase-firestore.js\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1firebase.js\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1login.js?v=2\"></script>\n      <script src=\"https://cdn.jsdelivr.net/gh/n-101-1/1@main/1firestore.js\"></script>\n      <script> \n        initializeFireBase();\n\n        function showAds() {\n            console.log(\"show ads\");\n        }\n\n        function requestNewAd() {\n            unityAdFinishedCallback();\n        }\n\n        function unityAdFinishedCallback() {\n            try {\n                if (gameInstance) gameInstance.SendMessage(\"AdsManager\", \"OnWebCallback\");\n            } catch (error) {\n                console.log(error);\n            }\n        }\n      </script> \n   </body>\n</html>"
  },
  {
    "id": "amanda-the-adventurer",
    "title": "Amanda The Adventurer",
    "description": "A horror-themed puzzle game where you watch old tapes of a children's show that starts to get creepy.",
    "thumbnail": "https://cdn.jsdelivr.net/gh/gn-math/covers@main/450.png",
    "html": "<!DOCTYPE html>\n<html lang=\"en-us\">\n\n<head>\n    <base href=\"https://cdn.jsdelivr.net/gh/genizy/web-port@main/amanda-the-adventurer/\">\n    <meta charset=\"utf-8\">\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">\n    <title>Unity WebGL Player | Amanda The Adventurer</title>\n    <link rel=\"shortcut icon\" href=\"TemplateData/favicon.ico\">\n    <link rel=\"stylesheet\" href=\"TemplateData/style.css\">\n    <style>\n        html,\n        body {\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            height: 100%;\n            width: 100%;\n        }\n\n        #unity-container {\n            width: 100%;\n            height: 100%;\n            position: fixed;\n            top: 0;\n            left: 0;\n        }\n    </style>\n</head>\n\n<body>\n    <div id=\"loading-text\" style=\"color: black; font-family: cursive; font-size: 48px; text-align: center; margin-top: 20px;\">LOADING...</div>\n    <div id=\"unity-container\" class=\"unity-desktop\" hidden>\n        <canvas id=\"unity-canvas\" width=960 height=600></canvas>\n        <div id=\"unity-loading-bar\">\n            <div id=\"unity-logo\"></div>\n            <div id=\"unity-progress-bar-empty\">\n                <div id=\"unity-progress-bar-full\"></div>\n            </div>\n        </div>\n        <div id=\"unity-warning\"> </div>\n    </div>\n    <script>\n\n        var container = document.querySelector(\"#unity-container\");\n        var canvas = document.querySelector(\"#unity-canvas\");\n        var loadingBar = document.querySelector(\"#unity-loading-bar\");\n        var progressBarFull = document.querySelector(\"#unity-progress-bar-full\");\n        var fullscreenButton = document.querySelector(\"#unity-fullscreen-button\");\n        var warningBanner = document.querySelector(\"#unity-warning\");\n        var loadingText = document.querySelector(\"#loading-text\");\n\n        function unityShowBanner(msg, type) {}\n\n        function mergeFiles(fileParts) {\n            return Promise.all(fileParts.map(part => fetch(part).then(res => res.arrayBuffer()).then(buf => {\n                doneparts++;\n                loadingText.textContent = `LOADING... (${doneparts}/${maxparts})`;\n                return buf;\n            }))).then(buffers => {\n                const mergedBlob = new Blob(buffers);\n                return URL.createObjectURL(mergedBlob);\n            });\n        }\n        let doneparts = 0;\n        let maxparts = 0;\n\n        function getParts(file, start, end) {\n            let parts = [];\n            for (let i = start; i <= end; i++) {\n                parts.push(file + \".part\" + i);\n            }\n            maxparts = maxparts + parts.length;\n            return parts;\n        }\n        const originalFetch = window.fetch;\n        window.fetch = async function (...args) {\n            const url = args[0];\n            if (typeof url === \"string\") {\n                if (url.includes(\"gn-math.github.io/Clip_Secret Tape 2.webm\")) {\n                    return new Response(f2Url, {\n                        status: 200\n                    });\n                } else if (url.includes(\"gn-math.github.io/Clip_Secret Tape 3.webm\")) {\n                    return new Response(f3Url, {\n                        status: 200\n                    });\n                } else if (url.includes(\"gn-math.github.io/Clip_Secret Tape 5.webm\")) {\n                    return new Response(f5Url, {\n                        status: 200\n                    });\n                } else if (url.includes(\"gn-math.github.io/Clip_Secret Tape 6.webm\")) {\n                    return new Response(f6Url, {\n                        status: 200\n                    });\n                }\n            }\n            return originalFetch.apply(this, args);\n        };\n        let f2Url = null;\n        let f6Url = null;\n        let f3Url = null;\n        let f5Url = null;\n        Promise.all([\n            mergeFiles(getParts(\"Build/Build.wasm\", 1, 4)),\n            mergeFiles(getParts(\"Build/Build.data\", 1, 63)),\n            // ---\n            mergeFiles(getParts(\"gn-math.github.io/Clip_Secret Tape 2.webm\", 1, 2)),\n            mergeFiles(getParts(\"gn-math.github.io/Clip_Secret Tape 6.webm\", 1, 2)),\n            mergeFiles(getParts(\"gn-math.github.io/Clip_Secret Tape 3.webm\", 1, 2)),\n            mergeFiles(getParts(\"gn-math.github.io/Clip_Secret Tape 5.webm\", 1, 3))\n        ]).then(([wasmUrl, dataUrl, f2, f6, f3, f5]) => {\n            f2Url = f2;\n            f6Url = f6;\n            f3Url = f3;\n            f5Url = f5;\n            container.hidden = false;\n            var buildUrl = \"Build\";\n            var loaderUrl = buildUrl + \"/Build.loader.js\";\n            var config = {\n                dataUrl: dataUrl,\n                frameworkUrl: buildUrl + \"/Build.framework.js\",\n                codeUrl: wasmUrl,\n                streamingAssetsUrl: \"StreamingAssets\",\n                companyName: \"MangledMaw\",\n                productName: \"Amanda The Adventurer\",\n                productVersion: \"1.6.17b\",\n                showBanner: unityShowBanner,\n            };\n            if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {\n                var meta = document.createElement('meta');\n                meta.name = 'viewport';\n                meta.content = 'width=device-width, height=device-height, initial-scale=1.0, user-scalable=no, shrink-to-fit=yes';\n                document.getElementsByTagName('head')[0].appendChild(meta);\n                container.className = \"unity-mobile\";\n                canvas.className = \"unity-mobile\";\n            } else {\n                function resizeCanvas() {\n                    canvas.width = window.innerWidth;\n                    canvas.height = window.innerHeight;\n                    canvas.style.width = window.innerWidth + \"px\";\n                    canvas.style.height = window.innerHeight + \"px\";\n                }\n                resizeCanvas();\n                window.addEventListener('resize', resizeCanvas);\n            }\n            loadingBar.style.display = \"block\";\n            var script = document.createElement(\"script\");\n            script.src = loaderUrl;\n            script.onload = () => {\n                createUnityInstance(canvas, config, (progress) => {\n                    progressBarFull.style.width = 100 * progress + \"%\";\n                }).then((unityInstance) => {\n                    loadingBar.style.display = \"none\";\n                    document.querySelector(\"#loading-text\").remove();\n                }).catch((message) => {\n                    alert(message);\n                });\n            };\n            document.body.appendChild(script);\n        });\n\n    </script>\n</body>\n</html>"
  },
